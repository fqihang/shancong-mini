.home-page {
  min-height: 100vh;
  padding-bottom: 56rpx;
  background: #f7f3ea;
}

.hero-showcase {
  position: relative;
  height: 820rpx;
  overflow: hidden;
}

.hero-image,
.hero-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-mask {
  background: linear-gradient(180deg, rgba(10, 18, 13, 0.08), rgba(10, 18, 13, 0.76));
}

.hero-content {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 54rpx;
  color: #ffffff;
}

.hero-kicker {
  font-size: 25rpx;
  line-height: 34rpx;
  font-weight: 700;
  opacity: 0.9;
}

.hero-title {
  margin-top: 16rpx;
  max-width: 650rpx;
  font-size: 58rpx;
  line-height: 70rpx;
  font-weight: 900;
}

.hero-text {
  margin-top: 18rpx;
  max-width: 590rpx;
  font-size: 28rpx;
  line-height: 42rpx;
  opacity: 0.92;
}

.hero-points {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 28rpx;
}

.hero-points text {
  padding: 9rpx 15rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.44);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  font-size: 23rpx;
}

.intro-band {
  padding: 44rpx 30rpx 22rpx;
}

.intro-location {
  color: #8b6546;
  font-size: 24rpx;
  font-weight: 800;
}

.intro-title {
  margin-top: 12rpx;
  color: #243027;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 900;
}

.intro-text {
  margin-top: 14rpx;
  color: #657168;
  font-size: 28rpx;
  line-height: 44rpx;
}

.gallery-stack {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 16rpx 24rpx 0;
}

.gallery-panel {
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
  background: #d8d0c1;
}

.feature-landscape {
  min-height: 640rpx;
}

.feature-image {
  width: 100%;
  height: 640rpx;
}

.gallery-copy {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 248, 0.9);
}

.static-copy {
  position: static;
  margin: 0;
  background: #fffdf8;
}

.gallery-eyebrow {
  color: #8b6546;
  font-size: 23rpx;
  font-weight: 800;
}

.gallery-title {
  margin-top: 10rpx;
  color: #243027;
  font-size: 40rpx;
  line-height: 50rpx;
  font-weight: 900;
}

.gallery-text {
  margin-top: 10rpx;
  color: #657168;
  font-size: 26rpx;
  line-height: 40rpx;
}

.portrait-pair {
  background: #fffdf8;
}

.portrait-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  padding: 0 24rpx 24rpx;
}

.portrait-image {
  width: 100%;
  height: 520rpx;
  border-radius: 8rpx;
  background: #d8d0c1;
}

.mixed-mosaic {
  background: #fffdf8;
}

.mosaic-wide {
  width: 100%;
  height: 430rpx;
  background: #d8d0c1;
}

.mosaic-row {
  display: grid;
  grid-template-columns: 1fr 240rpx;
  gap: 16rpx;
  padding: 24rpx;
}

.mosaic-copy {
  min-height: 360rpx;
  padding: 6rpx 0;
}

.mosaic-tall {
  width: 240rpx;
  height: 360rpx;
  border-radius: 8rpx;
  background: #d8d0c1;
}

.single-portrait {
  background: #fffdf8;
}

.single-portrait-image {
  width: 100%;
  height: 760rpx;
  background: #d8d0c1;
}

.rooms-section {
  padding: 46rpx 24rpx 0;
}

.section-title {
  color: #243027;
  font-size: 38rpx;
  line-height: 48rpx;
  font-weight: 900;
}

.section-subtitle {
  margin-top: 10rpx;
  color: #657168;
  font-size: 26rpx;
  line-height: 38rpx;
}

.room-grid {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 22rpx;
}

.room-tile {
  overflow: hidden;
  border-radius: 8rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 28rpx rgba(49, 42, 31, 0.08);
}

.room-image {
  width: 100%;
  height: 360rpx;
  background: #d8d0c1;
}

.room-body {
  padding: 22rpx;
}

.room-name {
  color: #243027;
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.room-line {
  margin-top: 8rpx;
  color: #657168;
  font-size: 25rpx;
  line-height: 38rpx;
}

.room-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.room-tags text {
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  background: #f1eadc;
  color: #5d655f;
  font-size: 22rpx;
}

.lead-band {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 36rpx 24rpx 0;
  padding: 26rpx;
  border-radius: 8rpx;
  background: #26352c;
  color: #ffffff;
}

.lead-title {
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 900;
}

.lead-text {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
  line-height: 36rpx;
}

.lead-button {
  flex-shrink: 0;
  width: 176rpx;
  min-height: 72rpx;
  border-radius: 8rpx;
  background: #fffdf8;
  color: #26352c;
  font-size: 26rpx;
  font-weight: 900;
}
