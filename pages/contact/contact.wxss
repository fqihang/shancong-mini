.contact-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  background: #f7f3ea;
}

.contact-hero {
  padding: 44rpx 28rpx;
  border-radius: 8rpx;
  background: #26352c;
  color: #ffffff;
}

.hero-kicker {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 800;
}

.hero-title {
  margin-top: 14rpx;
  font-size: 54rpx;
  line-height: 66rpx;
  font-weight: 900;
}

.hero-text {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 27rpx;
  line-height: 42rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 22rpx;
}

.quick-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 190rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 28rpx rgba(49, 42, 31, 0.08);
  text-align: left;
}

.quick-label,
.link-action {
  color: #8b6546;
  font-size: 23rpx;
  font-weight: 800;
}

.quick-value {
  flex: 1;
  margin-top: 18rpx;
  color: #243027;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 900;
  word-break: break-all;
}

.quick-action {
  margin-top: 14rpx;
  color: #2f6f4e;
  font-size: 24rpx;
  font-weight: 800;
}

.address-card,
.service-card {
  padding: 24rpx;
}

.address-text,
.service-text,
.link-summary {
  color: #68746c;
  font-size: 26rpx;
  line-height: 40rpx;
}

.address-text {
  margin-top: 14rpx;
}

.address-button {
  margin-top: 22rpx;
  min-height: 78rpx;
  font-size: 27rpx;
}

.service-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.service-button {
  width: 150rpx;
  min-height: 74rpx;
  font-size: 26rpx;
}

.link-section {
  margin-top: 34rpx;
}

.link-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.link-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  min-height: 132rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #fffdf8;
  text-align: left;
  box-shadow: 0 12rpx 28rpx rgba(49, 42, 31, 0.08);
}

.link-title {
  color: #243027;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 900;
}

.link-summary {
  margin-top: 8rpx;
}

.link-action {
  flex-shrink: 0;
}
