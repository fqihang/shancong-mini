.booking-page {
  padding-bottom: 60rpx;
}

.room-summary {
  display: flex;
}

.room-cover {
  flex-shrink: 0;
  width: 220rpx;
  height: 180rpx;
  background: #d8d0c1;
}

.room-info {
  flex: 1;
  min-width: 0;
  padding: 18rpx;
}

.room-name {
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 800;
}

.room-meta {
  margin-top: 8rpx;
  color: #68746c;
  font-size: 24rpx;
  line-height: 34rpx;
}

.form-card {
  padding: 22rpx;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.field,
.input-field {
  padding: 18rpx;
  border: 1rpx solid rgba(36, 48, 39, 0.1);
  border-radius: 8rpx;
  background: #fffaf1;
}

.guest-field {
  grid-column: span 2;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #7c857e;
  font-size: 22rpx;
}

.field-value,
.input-field input,
.input-field textarea {
  width: 100%;
  min-height: 48rpx;
  color: #243027;
  font-size: 28rpx;
  font-weight: 700;
}

.input-field {
  margin-top: 16rpx;
}

.input-field textarea {
  line-height: 38rpx;
  font-weight: 400;
}

.guest-stepper {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stepper-button {
  width: 64rpx;
  height: 56rpx;
  border-radius: 8rpx;
  background: #e4f0e7;
  color: #2f6f4e;
  font-size: 34rpx;
  font-weight: 800;
}

.guest-count {
  font-size: 32rpx;
  font-weight: 800;
}

.quote-row,
.quote-total {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  color: #68746c;
  font-size: 26rpx;
}

.quote-total {
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(36, 48, 39, 0.1);
  color: #243027;
  font-size: 34rpx;
  font-weight: 900;
}

.submit-button {
  margin-top: 28rpx;
}
