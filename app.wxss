page {
  min-height: 100vh;
  background: #f7f3ea;
  color: #243027;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  letter-spacing: 0;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font-size: inherit;
}

button::after {
  border: 0;
}

.page {
  padding: 24rpx 24rpx 48rpx;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #68746c;
  font-size: 24rpx;
  line-height: 34rpx;
}

.card {
  border: 1rpx solid rgba(36, 48, 39, 0.08);
  border-radius: 8rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 28rpx rgba(49, 42, 31, 0.08);
  overflow: hidden;
}

.pill {
  display: inline-flex;
  align-items: center;
  height: 52rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(36, 48, 39, 0.14);
  border-radius: 999rpx;
  color: #526057;
  background: rgba(255, 253, 248, 0.8);
  font-size: 24rpx;
  white-space: nowrap;
}

.pill.active {
  border-color: #2f6f4e;
  color: #ffffff;
  background: #2f6f4e;
}

.primary-button,
.secondary-button,
.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-button {
  color: #ffffff;
  background: #2f6f4e;
}

.secondary-button {
  color: #2f6f4e;
  background: #e4f0e7;
}

.ghost-button {
  border: 1rpx solid rgba(36, 48, 39, 0.14);
  color: #324039;
  background: #fffdf8;
}

.muted {
  color: #68746c;
}

.price {
  color: #9a4f25;
  font-weight: 800;
}

.empty {
  padding: 80rpx 32rpx;
  text-align: center;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 14rpx;
  color: #68746c;
  font-size: 26rpx;
  line-height: 38rpx;
}
