<view wx:if="{{room}}" class="page booking-page">
  <view class="room-summary card">
    <image class="room-cover" src="{{room.cover}}" mode="aspectFill" />
    <view class="room-info">
      <view class="room-name">{{room.name}}</view>
      <view class="room-meta">{{room.city}} · {{room.area}} · 最多 {{room.capacity}} 人</view>
      <view class="price">¥{{room.price}}/晚</view>
    </view>
  </view>

  <view class="section card form-card">
    <view class="section-title">行程信息</view>
    <view class="field-grid">
      <view class="field">
        <text class="field-label">入住</text>
        <picker mode="date" value="{{checkIn}}" bindchange="onCheckInChange">
          <view class="field-value">{{checkIn}}</view>
        </picker>
      </view>
      <view class="field">
        <text class="field-label">离店</text>
        <picker mode="date" value="{{checkOut}}" bindchange="onCheckOutChange">
          <view class="field-value">{{checkOut}}</view>
        </picker>
      </view>
      <view class="field guest-field">
        <text class="field-label">入住人数</text>
        <view class="guest-stepper">
          <button class="stepper-button" bindtap="decreaseGuests">-</button>
          <text class="guest-count">{{guests}}</text>
          <button class="stepper-button" bindtap="increaseGuests">+</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section card form-card">
    <view class="section-title">联系人</view>
    <view class="input-field">
      <text class="field-label">姓名</text>
      <input value="{{contactName}}" data-field="contactName" placeholder="填写入住联系人" bindinput="onFieldInput" />
    </view>
    <view class="input-field">
      <text class="field-label">手机号</text>
      <input value="{{phone}}" data-field="phone" type="number" maxlength="11" placeholder="用于房东确认订单" bindinput="onFieldInput" />
    </view>
    <view class="input-field">
      <text class="field-label">预计到店</text>
      <picker mode="selector" range="{{arrivalOptions}}" value="{{arrivalIndex}}" bindchange="onArrivalChange">
        <view class="field-value">{{arrivalTime}}</view>
      </picker>
    </view>
    <view class="input-field">
      <text class="field-label">备注</text>
      <textarea value="{{remark}}" data-field="remark" auto-height maxlength="120" placeholder="如儿童、宠物、早餐、停车等需求" bindinput="onFieldInput" />
    </view>
  </view>

  <view class="section card form-card">
    <view class="section-title">费用明细</view>
    <view class="quote-row">
      <text>房费 ¥{{room.price}} × {{nights}} 晚</text>
      <text>¥{{roomTotal}}</text>
    </view>
    <view class="quote-row">
      <text>服务费</text>
      <text>¥{{serviceFee}}</text>
    </view>
    <view class="quote-total">
      <text>应付</text>
      <text>¥{{payable}}</text>
    </view>
  </view>

  <button class="primary-button submit-button" bindtap="submitBooking">提交预订</button>
</view>
