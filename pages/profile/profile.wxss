.profile-page {
  padding-top: 32rpx;
}

.profile-hero {
  padding: 34rpx 28rpx;
  border-radius: 8rpx;
  background: #26352c;
  color: #ffffff;
}

.profile-kicker {
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0.78;
}

.profile-title {
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 52rpx;
  font-weight: 900;
}

.profile-text {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  line-height: 38rpx;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.check-card {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
}

.check-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e4f0e7;
  color: #2f6f4e;
  font-size: 26rpx;
  font-weight: 900;
}

.check-title {
  font-size: 30rpx;
  font-weight: 800;
}

.check-desc {
  margin-top: 8rpx;
  color: #68746c;
  font-size: 25rpx;
  line-height: 38rpx;
}

.service-button {
  margin-top: 28rpx;
}
