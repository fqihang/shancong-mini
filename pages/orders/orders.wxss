.orders-page {
  padding-top: 32rpx;
}

.empty {
  margin-top: 28rpx;
}

.empty-button {
  margin-top: 28rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 28rpx;
}

.order-card {
  display: flex;
  flex-direction: column;
}

.order-cover {
  width: 100%;
  height: 280rpx;
  background: #d8d0c1;
}

.order-body {
  padding: 22rpx;
}

.order-header,
.order-footer {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-name {
  font-size: 32rpx;
  line-height: 42rpx;
  font-weight: 800;
}

.order-meta,
.order-line {
  color: #68746c;
  font-size: 24rpx;
  line-height: 34rpx;
}

.order-line {
  margin-top: 10rpx;
}

.status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e4f0e7;
  color: #2f6f4e;
  font-size: 22rpx;
  font-weight: 800;
}

.status.cancelled {
  background: #eee6dc;
  color: #8a6c58;
}

.order-footer {
  align-items: center;
  margin-top: 20rpx;
}

.order-actions {
  display: flex;
  gap: 12rpx;
}

.ghost-mini,
.danger-mini {
  min-width: 132rpx;
  min-height: 58rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.ghost-mini {
  border: 1rpx solid rgba(36, 48, 39, 0.14);
  color: #324039;
  background: #fffdf8;
}

.danger-mini {
  color: #9a4f25;
  background: #fff0e8;
}
