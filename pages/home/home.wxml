<view class="home-page">
  <view class="hero-showcase">
    <image class="hero-image" src="{{site.hero.image}}" mode="aspectFill" />
    <view class="hero-mask"></view>
    <view class="hero-content">
      <view class="hero-kicker">{{site.hero.kicker}}</view>
      <view class="hero-title">{{site.hero.title}}</view>
      <view class="hero-text">{{site.hero.text}}</view>
      <view class="hero-points">
        <text wx:for="{{sellingPoints}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="intro-band">
    <view class="intro-location">{{site.locationText}}</view>
    <view class="intro-title">{{site.intro.title}}</view>
    <view class="intro-text">{{site.intro.text}}</view>
  </view>

  <view class="gallery-stack">
    <block wx:for="{{gallerySections}}" wx:key="id">
      <view wx:if="{{item.template == 'feature_landscape'}}" class="gallery-panel feature-landscape">
        <image class="feature-image" src="{{item.slots.cover.src}}" mode="aspectFill" />
        <view class="gallery-copy">
          <view class="gallery-eyebrow">{{item.copy.eyebrow}}</view>
          <view class="gallery-title">{{item.copy.title}}</view>
          <view class="gallery-text">{{item.copy.text}}</view>
        </view>
      </view>

      <view wx:elif="{{item.template == 'portrait_pair'}}" class="gallery-panel portrait-pair">
        <view class="gallery-copy static-copy">
          <view class="gallery-eyebrow">{{item.copy.eyebrow}}</view>
          <view class="gallery-title">{{item.copy.title}}</view>
          <view class="gallery-text">{{item.copy.text}}</view>
        </view>
        <view class="portrait-grid">
          <image class="portrait-image" src="{{item.slots.left.src}}" mode="aspectFill" />
          <image class="portrait-image" src="{{item.slots.right.src}}" mode="aspectFill" />
        </view>
      </view>

      <view wx:elif="{{item.template == 'mixed_mosaic'}}" class="gallery-panel mixed-mosaic">
        <image class="mosaic-wide" src="{{item.slots.wide.src}}" mode="aspectFill" />
        <view class="mosaic-row">
          <view class="mosaic-copy">
            <view class="gallery-eyebrow">{{item.copy.eyebrow}}</view>
            <view class="gallery-title">{{item.copy.title}}</view>
            <view class="gallery-text">{{item.copy.text}}</view>
          </view>
          <image class="mosaic-tall" src="{{item.slots.tall.src}}" mode="aspectFill" />
        </view>
      </view>

      <view wx:elif="{{item.template == 'single_portrait'}}" class="gallery-panel single-portrait">
        <image class="single-portrait-image" src="{{item.slots.cover.src}}" mode="aspectFill" />
        <view class="gallery-copy static-copy">
          <view class="gallery-eyebrow">{{item.copy.eyebrow}}</view>
          <view class="gallery-title">{{item.copy.title}}</view>
          <view class="gallery-text">{{item.copy.text}}</view>
        </view>
      </view>
    </block>
  </view>

  <view class="rooms-section">
    <view class="section-title">房间掠影</view>
    <view class="section-subtitle">先看空间气质，想了解细节可以直接联系店主。</view>
    <view class="room-grid">
      <view wx:for="{{rooms}}" wx:key="id" class="room-tile" data-id="{{item.id}}" bindtap="goDetail">
        <image class="room-image" src="{{item.cover}}" mode="aspectFill" />
        <view class="room-body">
          <view class="room-name">{{item.name}}</view>
          <view class="room-line">{{item.tagline}}</view>
          <view class="room-tags">
            <text wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="lead-band">
    <view>
      <view class="lead-title">想了解山里的真实情况？</view>
      <view class="lead-text">电话、微信、地址和平台入口都整理在这里，出发前先确认更稳。</view>
    </view>
    <button class="lead-button" bindtap="goContact">联系山从</button>
  </view>
</view>
