.detail-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: #f7f3ea;
}

.gallery {
  width: 100%;
  height: 560rpx;
  background: #d8d0c1;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.content {
  padding: 24rpx;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.location,
.tagline,
.host-response,
.policy-item {
  color: #68746c;
  font-size: 26rpx;
  line-height: 38rpx;
}

.room-name {
  margin-top: 8rpx;
  font-size: 42rpx;
  line-height: 52rpx;
  font-weight: 800;
}

.rating {
  flex-shrink: 0;
  padding: 10rpx 14rpx;
  border-radius: 6rpx;
  background: #fff8e8;
  color: #9a4f25;
  font-size: 24rpx;
  font-weight: 800;
}

.tagline {
  margin-top: 12rpx;
}

.fact-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.fact {
  min-height: 128rpx;
  padding: 18rpx 12rpx;
  border-radius: 8rpx;
  background: #fffdf8;
  text-align: center;
}

.fact-value {
  display: block;
  min-height: 38rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.fact-label {
  display: block;
  margin-top: 10rpx;
  color: #68746c;
  font-size: 22rpx;
}

.booking-card {
  padding: 22rpx;
}

.booking-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.booking-field {
  padding: 16rpx;
  border: 1rpx solid rgba(36, 48, 39, 0.1);
  border-radius: 8rpx;
  background: #fffaf1;
  color: #243027;
  font-size: 28rpx;
  font-weight: 700;
}

.booking-field > text {
  display: block;
  margin-bottom: 10rpx;
  color: #7c857e;
  font-size: 22rpx;
  font-weight: 400;
}

.guest-field {
  grid-column: span 2;
}

.guest-stepper {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stepper-button {
  width: 64rpx;
  height: 56rpx;
  border-radius: 8rpx;
  background: #e4f0e7;
  color: #2f6f4e;
  font-size: 34rpx;
  font-weight: 800;
}

.quote-row,
.quote-total {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  color: #68746c;
  font-size: 26rpx;
}

.quote-total {
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(36, 48, 39, 0.1);
  color: #243027;
  font-size: 32rpx;
  font-weight: 800;
}

.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.highlight-item,
.policy-item {
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #fffdf8;
}

.amenity-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.amenity {
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #fffdf8;
  color: #324039;
  font-size: 26rpx;
}

.host-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx;
}

.host-name {
  font-size: 30rpx;
  font-weight: 800;
}

.host-button {
  width: 180rpx;
  min-height: 72rpx;
  font-size: 26rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 24rpx 30rpx;
  border-top: 1rpx solid rgba(36, 48, 39, 0.08);
  background: rgba(255, 253, 248, 0.96);
}

.bottom-price {
  color: #9a4f25;
  font-size: 38rpx;
  font-weight: 900;
}

.bottom-unit {
  color: #68746c;
  font-size: 22rpx;
}

.book-button {
  width: 280rpx;
}
